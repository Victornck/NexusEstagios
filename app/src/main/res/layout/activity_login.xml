<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF6B00"
    android:orientation="vertical"
    android:gravity="center">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="28dp"
            android:paddingTop="60dp"
            android:paddingBottom="40dp">

            <!-- LOGO / ÍCONE -->
            <LinearLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_logo_circle"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="N"
                    android:textColor="#FF6B00"
                    android:textSize="38sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- TITULO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="EstágioApp"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Gerencie seu estágio com facilidade"
                android:textColor="#FFD4B3"
                android:textSize="14sp" />

            <!-- SELEÇÃO DE PERFIL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:layout_marginBottom="12dp"
                android:text="Entrar como"
                android:textColor="#FFD4B3"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3">

                <!-- ALUNO -->
                <LinearLayout
                    android:id="@+id/btn_perfil_aluno"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_perfil_selected"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_aluno" />

                    <TextView
                        android:id="@+id/txt_perfil_aluno"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Aluno"
                        android:textColor="#FF6B00"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- SUPERVISOR -->
                <LinearLayout
                    android:id="@+id/btn_perfil_supervisor"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="3dp"
                    android:background="@drawable/bg_perfil_unselected"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_supervisor" />

                    <TextView
                        android:id="@+id/txt_perfil_supervisor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Supervisor"
                        android:textColor="#FFD4B3"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- EMPRESA -->
                <LinearLayout
                    android:id="@+id/btn_perfil_empresa"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_perfil_unselected"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_empresa" />

                    <TextView
                        android:id="@+id/txt_perfil_empresa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Empresa"
                        android:textColor="#FFD4B3"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- CARD FORMULARIO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_card"
                android:elevation="4dp"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- EMAIL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="E-mail"
                    android:textColor="#888888"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:hint="seu@email.com"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="14dp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#BBBBBB"
                    android:textSize="15sp" />

                <!-- SENHA -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Senha"
                    android:textColor="#888888"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/et_senha"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:paddingHorizontal="14dp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#BBBBBB"
                    android:textSize="15sp" />

                <!-- ESQUECI SENHA -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_gravity="end"
                    android:text="Esqueci minha senha"
                    android:textColor="#FF6B00"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- BOTÃO ENTRAR -->
            <TextView
                android:id="@+id/btn_entrar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_card"
                android:gravity="center"
                android:text="Entrar"
                android:textColor="#FF6B00"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- CADASTRO -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Não tem conta? "
                    android:textColor="#FFD4B3"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/btn_cadastrar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cadastre-se"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
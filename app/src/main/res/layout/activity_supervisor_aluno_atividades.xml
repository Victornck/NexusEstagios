<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FF6B00"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="18dp"
                android:paddingBottom="22dp">

                <!-- TOPO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- VOLTAR -->
                    <TextView
                        android:id="@+id/btn_voltar"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="←"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <!-- INFO -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Atividades do aluno"
                            android:textColor="#FFD4B3"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/tv_nome_aluno"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Aluno"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                    <!-- AVATAR -->
                    <LinearLayout
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_logo_circle"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_avatar_aluno"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="JV"
                            android:textColor="#FF6B00"
                            android:textSize="18sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- CURSO -->
                <TextView
                    android:id="@+id/tv_curso_aluno"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Curso"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"/>

                <!-- STATUS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_perfil_unselected"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:weightSum="3">

                    <!-- TOTAL -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_total_atividades"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Atividades"
                            android:textColor="#FFD4B3"
                            android:textSize="11sp"/>

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="36dp"
                        android:background="#FF9955"/>

                    <!-- PENDENTES -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_pendentes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pendentes"
                            android:textColor="#FFD4B3"
                            android:textSize="11sp"/>

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="36dp"
                        android:background="#FF9955"/>

                    <!-- CONCLUÍDAS -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_concluidas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Concluídas"
                            android:textColor="#FFD4B3"
                            android:textSize="11sp"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- TÍTULO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:text="Lista de atividades"
                android:textColor="#1A1A1A"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <!-- CONTAINER -->
            <LinearLayout
                android:id="@+id/container_atividades"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="20dp"
                android:orientation="vertical"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:orientation="vertical">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <TextView
            android:id="@+id/btn_voltar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="← Voltar"
            android:textColor="#FF6B00"
            android:textSize="15sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Candidatura"
            android:textColor="#1A1A1A"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text=""
            android:textSize="15sp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- VAGA CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Candidatando-se para"
                    android:textColor="#888888"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_nome_vaga"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text=""
                    android:textColor="#FF6B00"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_empresa_vaga"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text=""
                    android:textColor="#888888"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- NOME -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Nome completo"
                android:textColor="#888888"
                android:textSize="12sp" />
            <EditText
                android:id="@+id/et_nome"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_card"
                android:inputType="textPersonName"
                android:paddingHorizontal="14dp"
                android:textColor="#1A1A1A"
                android:textSize="15sp" />

            <!-- EMAIL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="E-mail"
                android:textColor="#888888"
                android:textSize="12sp" />
            <EditText
                android:id="@+id/et_email"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_card"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="14dp"
                android:textColor="#1A1A1A"
                android:textSize="15sp" />

            <!-- TELEFONE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Telefone"
                android:textColor="#888888"
                android:textSize="12sp" />
            <EditText
                android:id="@+id/et_telefone"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_card"
                android:inputType="phone"
                android:paddingHorizontal="14dp"
                android:textColor="#1A1A1A"
                android:textSize="15sp" />

            <!-- EXPERIENCIA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Possui experiência na área?"
                android:textColor="#888888"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/btn_sim"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_inactive"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/txt_sim"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓  Sim"
                        android:textColor="#444444"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_nao"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_inactive"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/txt_nao"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✗  Não"
                        android:textColor="#444444"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>

            <!-- PRETENSAO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Pretensão salarial (R$)"
                android:textColor="#888888"
                android:textSize="12sp" />
            <EditText
                android:id="@+id/et_pretensao"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_card"
                android:hint="Ex: 1.500,00"
                android:inputType="numberDecimal"
                android:paddingHorizontal="14dp"
                android:textColor="#1A1A1A"
                android:textColorHint="#BBBBBB"
                android:textSize="15sp" />

            <!-- MENSAGEM -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Apresentação / Mensagem"
                android:textColor="#888888"
                android:textSize="12sp" />
            <EditText
                android:id="@+id/et_mensagem"
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_card"
                android:gravity="top"
                android:hint="Fale um pouco sobre você..."
                android:inputType="textMultiLine"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp"
                android:textColor="#1A1A1A"
                android:textColorHint="#BBBBBB"
                android:textSize="15sp" />

        </LinearLayout>
    </ScrollView>

    <!-- BOTÃO ENVIAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:padding="16dp">

        <TextView
            android:id="@+id/btn_enviar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_button_orange"
            android:gravity="center"
            android:text="Enviar candidatura"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF6B00"
    android:orientation="vertical">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/btn_voltar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="← Voltar"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Criar conta"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text=""
            android:textSize="15sp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="32dp">

            <!-- SELEÇÃO DE PERFIL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="Tipo de conta"
                android:textColor="#FFD4B3"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3">

                <LinearLayout
                    android:id="@+id/btn_tipo_aluno"
                    android:layout_width="0dp"
                    android:layout_height="68dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_perfil_selected"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_aluno" />
                    <TextView
                        android:id="@+id/txt_tipo_aluno"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Aluno"
                        android:textColor="#FF6B00"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_tipo_supervisor"
                    android:layout_width="0dp"
                    android:layout_height="68dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="3dp"
                    android:background="@drawable/bg_perfil_unselected"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_supervisor" />
                    <TextView
                        android:id="@+id/txt_tipo_supervisor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Supervisor"
                        android:textColor="#FFD4B3"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_tipo_empresa"
                    android:layout_width="0dp"
                    android:layout_height="68dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_perfil_unselected"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_empresa" />
                    <TextView
                        android:id="@+id/txt_tipo_empresa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Empresa"
                        android:textColor="#FFD4B3"
                        android:textSize="12sp" />
                </LinearLayout>

            </LinearLayout>

            <!-- CARD CAMPOS BASE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card"
                android:elevation="4dp"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- NOME -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nome completo"
                    android:textColor="#888888"
                    android:textSize="12sp" />
                <EditText
                    android:id="@+id/et_nome"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:hint="Seu nome completo"
                    android:inputType="textPersonName"
                    android:paddingHorizontal="14dp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#BBBBBB"
                    android:textSize="15sp" />

                <!-- CPF -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="CPF"
                    android:textColor="#888888"
                    android:textSize="12sp" />
                <EditText
                    android:id="@+id/et_cpf"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:hint="000.000.000-00"
                    android:inputType="number"
                    android:paddingHorizontal="14dp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#BBBBBB"
                    android:textSize="15sp" />

                <!-- DATA NASCIMENTO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Data de nascimento"
                    android:textColor="#888888"
                    android:textSize="12sp" />
                <EditText
                    android:id="@+id/et_nascimento"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:hint="DD/MM/AAAA"
                    android:inputType="number"
                    android:paddingHorizontal="14dp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#BBBBBB"
                    android:textSize="15sp" />

                <!-- TELEFONE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Telefone"
                    android:textColor="#888888"
                    android:textSize="12sp" />
                <EditText
                    android:id="@+id/et_telefone"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:hint="(00) 00000-0000"
                    android:inputType="phone"
                    android:paddingHorizontal="14dp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#BBBBBB"
                    android:textSize="15sp" />

                <!-- EMAIL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="E-mail"
                    android:textColor="#888888"
                    android:textSize="12sp" />
                <EditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:hint="seu@email.com"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="14dp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#BBBBBB"
                    android:textSize="15sp" />

                <!-- SENHA -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Senha"
                    android:textColor="#888888"
                    android:textSize="12sp" />
                <EditText
                    android:id="@+id/et_senha"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:hint="Mínimo 6 caracteres"
                    android:inputType="textPassword"
                    android:paddingHorizontal="14dp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#BBBBBB"
                    android:textSize="15sp" />

                <!-- CONFIRMAR SENHA -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Confirmar senha"
                    android:textColor="#888888"
                    android:textSize="12sp" />
                <EditText
                    android:id="@+id/et_confirmar_senha"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:hint="Repita a senha"
                    android:inputType="textPassword"
                    android:paddingHorizontal="14dp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#BBBBBB"
                    android:textSize="15sp" />

            </LinearLayout>

            <!-- CARD CAMPOS ESPECÍFICOS -->
            <LinearLayout
                android:id="@+id/card_campos_extras"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card"
                android:elevation="4dp"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- ALUNO: curso + semestre -->
                <LinearLayout
                    android:id="@+id/campos_aluno"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Curso"
                        android:textColor="#888888"
                        android:textSize="12sp" />
                    <EditText
                        android:id="@+id/et_curso"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input"
                        android:hint="Ex: Ciência da Computação"
                        android:inputType="text"
                        android:paddingHorizontal="14dp"
                        android:textColor="#1A1A1A"
                        android:textColorHint="#BBBBBB"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Semestre atual"
                        android:textColor="#888888"
                        android:textSize="12sp" />
                    <EditText
                        android:id="@+id/et_semestre"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input"
                        android:hint="Ex: 6"
                        android:inputType="number"
                        android:paddingHorizontal="14dp"
                        android:textColor="#1A1A1A"
                        android:textColorHint="#BBBBBB"
                        android:textSize="15sp" />

                </LinearLayout>

                <!-- SUPERVISOR: matrícula + instituição -->
                <LinearLayout
                    android:id="@+id/campos_supervisor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Matrícula"
                        android:textColor="#888888"
                        android:textSize="12sp" />
                    <EditText
                        android:id="@+id/et_matricula"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input"
                        android:hint="Número de matrícula"
                        android:inputType="text"
                        android:paddingHorizontal="14dp"
                        android:textColor="#1A1A1A"
                        android:textColorHint="#BBBBBB"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Instituição"
                        android:textColor="#888888"
                        android:textSize="12sp" />
                    <EditText
                        android:id="@+id/et_instituicao"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input"
                        android:hint="Nome da instituição"
                        android:inputType="text"
                        android:paddingHorizontal="14dp"
                        android:textColor="#1A1A1A"
                        android:textColorHint="#BBBBBB"
                        android:textSize="15sp" />

                </LinearLayout>

                <!-- EMPRESA: CNPJ + razão social -->
                <LinearLayout
                    android:id="@+id/campos_empresa"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CNPJ"
                        android:textColor="#888888"
                        android:textSize="12sp" />
                    <EditText
                        android:id="@+id/et_cnpj"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input"
                        android:hint="00.000.000/0000-00"
                        android:inputType="number"
                        android:paddingHorizontal="14dp"
                        android:textColor="#1A1A1A"
                        android:textColorHint="#BBBBBB"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Razão social"
                        android:textColor="#888888"
                        android:textSize="12sp" />
                    <EditText
                        android:id="@+id/et_razao_social"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input"
                        android:hint="Nome da empresa"
                        android:inputType="text"
                        android:paddingHorizontal="14dp"
                        android:textColor="#1A1A1A"
                        android:textColorHint="#BBBBBB"
                        android:textSize="15sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- BOTÃO CADASTRAR -->
            <TextView
                android:id="@+id/btn_cadastrar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_card"
                android:gravity="center"
                android:text="Criar conta"
                android:textColor="#FF6B00"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="Ao criar uma conta você concorda com\nnos Termos de Uso e Política de Privacidade"
                android:textColor="#FFD4B3"
                android:textSize="11sp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
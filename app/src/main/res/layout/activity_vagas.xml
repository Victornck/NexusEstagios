<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:orientation="vertical">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vagas de estágio"
            android:textColor="#1A1A1A"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_total_vagas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Carregando..."
            android:textColor="#888888"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- FILTERS -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/chip_todas"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:background="@drawable/bg_chip_active"
                android:gravity="center"
                android:paddingHorizontal="18dp"
                android:text="Todas"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chip_tech"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_inactive"
                android:gravity="center"
                android:paddingHorizontal="18dp"
                android:text="Tech"
                android:textColor="#444444"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chip_design"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_inactive"
                android:gravity="center"
                android:paddingHorizontal="18dp"
                android:text="Design"
                android:textColor="#444444"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chip_marketing"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_inactive"
                android:gravity="center"
                android:paddingHorizontal="18dp"
                android:text="Marketing"
                android:textColor="#444444"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chip_financas"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_inactive"
                android:gravity="center"
                android:paddingHorizontal="18dp"
                android:text="Finanças"
                android:textColor="#444444"
                android:textSize="13sp" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/container_vagas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <!-- Cards serão adicionados aqui dinamicamente -->

            <TextView
                android:id="@+id/tv_sem_vagas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:gravity="center"
                android:text="Nenhuma vaga disponível no momento."
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV PADRONIZADO -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- INÍCIO -->
        <LinearLayout
            android:id="@+id/nav_inicio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_home"
                app:tint="#9E9E9E" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Início"
                android:textColor="#9E9E9E"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- VAGAS -->
        <LinearLayout
            android:id="@+id/nav_vagas"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="40dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_nav_active"
                android:gravity="center">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_briefcase"
                    app:tint="#FFFFFF" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Vagas"
                android:textColor="#FF6B00"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- ATIVIDADES -->
        <LinearLayout
            android:id="@+id/nav_atividades"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_check_nav"
                app:tint="#9E9E9E" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Atividades"
                android:textColor="#9E9E9E"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- PERFIL -->
        <LinearLayout
            android:id="@+id/nav_perfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_person"
                app:tint="#9E9E9E" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Perfil"
                android:textColor="#9E9E9E"
                android:textSize="11sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>